{
  "name": "givens-field-tools",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo-google-fonts/oswald": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.9",
    "expo-constants": "~56.0.17",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.5",
    "expo-image": "~56.0.10",
    "expo-image-manipulator": "~56.0.19",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-location": "~56.0.16",
    "expo-router": "~56.2.9",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^56.0.14",
    "tsx": "^4.20.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "npx tsx --test lib/**/*.test.ts",
    "prebuild:ios": "expo prebuild --platform ios",
    "build:apk": "expo prebuild --platform android --clean && cd android && ./gradlew assembleRelease && cd .. && cp android/app/build/outputs/apk/release/app-release.apk ./GivensFieldTools.apk",
    "build:apk:release": "eas build --platform android --profile preview --local --non-interactive"
  },
  "private": true
}
