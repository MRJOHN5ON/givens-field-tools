{
  "expo": {
    "name": "Givens Field Tools",
    "slug": "givens-field-tools",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "givensfieldtools",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.givensfire.fieldtools",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "android": {
      "package": "com.givensfire.fieldtools",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-image",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Givens Field Tools uses your location to screen wildfire risk at your current position."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
